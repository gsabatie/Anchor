# Google Cloud
GOOGLE_CLOUD_PROJECT=anchor-erp
GOOGLE_CLOUD_REGION=europe-west1

# Gemini Live API Key (required for WebSocket audio)
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Vertex AI (Imagen 3)
VERTEX_LOCATION=europe-west1
IMAGEN_MODEL=imagegeneration@006

# Firestore
FIRESTORE_COLLECTION=sessions

# App
ENV=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
VITE_BACKEND_WS_URL=ws://localhost:8000
VITE_WS_AUTH_TOKEN=test-token

# Security - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WS_AUTH_TOKEN=change-me-to-a-secure-random-value
VITE_WS_AUTH_TOKEN=change-me-to-a-secure-random-value
